{
  "name": "comparar-dfe-dominio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server.ts\" \"esbuild src/web/app.ts --bundle --outfile=public/app.js --sourcemap --watch\"",
    "build": "esbuild src/web/app.ts --bundle --minify --outfile=public/app.js && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.1",
    "playwright-core": "^1.61.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
